# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 通义千问 API (用于 AI Agent 排程)
# 不要带 VITE_ 前缀（不要暴露到前端 bundle）
# 开发：放这里或 .env.local（Vite dev server 通过 vite.config.ts 的 agentProxy 处理）
# 生产（Vercel）：在 Vercel Project Settings → Environment Variables 添加 DASHSCOPE_API_KEY，然后 Redeploy
# 获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-...
